        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint .",
        "format": "prettier --write --experimental-cli .",
        "check": "bunx tsc --noEmit",
        "test": "vitest run",
        "test:eval": "vitest run --config vitest.config.eval.ts",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest --coverage",
        "preflight": "bun run format && concurrently --kill-others-on-fail -n check,lint,test \"bun run check\" \"bun run lint\" \"bun run test\"",
